<%
  const isNested = Boolean(typeof nested !== 'undefined' && nested);
  const leaderboard = data_json(block.data || 'leaderboard');
  const metrics = leaderboard.metrics || [];
  const activeMetric = metrics[0];
  const metricKey = activeMetric?.key;
  const scoreMode = 'base';
  const agents = [...(leaderboard.agents || [])].sort((a, b) => {
    const aValue = Number(a.scores?.[scoreMode]?.[metricKey] ?? a[metricKey] ?? 0);
    const bValue = Number(b.scores?.[scoreMode]?.[metricKey] ?? b[metricKey] ?? 0);
    return bValue - aValue || String(a.agent || '').localeCompare(String(b.agent || ''));
  });
%>
<% if (!isNested) { %>
  <section class="band compact-band">
    <div class="inner">
<% } %>
<div data-component="leaderboard">
  <script type="application/json" data-leaderboard-json><%- script_json(leaderboard) %></script>
  <%- partial('_partial/leaderboard-table', { leaderboard, metrics, activeMetric, scoreMode, agents }) %>
</div>
<% if (!isNested) { %>
    </div>
  </section>
<% } %>
